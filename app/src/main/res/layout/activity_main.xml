<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgColor"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- AppBarLayout enveloppant ton layout custom -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="@color/bgColor">

        <!-- Ta "toolbar" custom -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mainAppBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_page_item"
            android:backgroundTint="@color/bgColorBis"
            android:fitsSystemWindows="false">

            <!-- Conteneur horizontal -->
            <LinearLayout
                android:id="@+id/appBarContent"
                android:layout_width="0dp"
                android:layout_height="?attr/actionBarSize"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Icône hamburger -->
                <ImageView
                    android:id="@+id/menuIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="18dp"
                    android:src="@drawable/ic_menu_hamburger"
                    android:contentDescription="Menu icon" />

                <!-- Titre -->
                <TextView
                    android:id="@+id/toolbarTitle"
                    android:layout_width="282dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-light"

                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:text="Memories of Lilas"
                    android:textColor="@color/textColor"
                    android:textSize="24sp" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/menu_item"
            android:hint="Rechercher..."
            android:inputType="text"
            android:paddingHorizontal="18dp"
            android:singleLine="true"
            android:textColor="@color/textColor"
            android:textColorHint="@color/textColorBis"
            android:textSize="16sp" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ScrollView qui démarre sous la barre grâce au comportement -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:contentDescription="srollview des pages"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/listContentWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/emptyStateContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@drawable/menu_panel_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/emptyStateIcon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/menu_icon_pill"
                    android:gravity="center"
                    android:text="✦"
                    android:textColor="@color/textColor"
                    android:textSize="30sp" />

                <TextView
                    android:id="@+id/emptyStateTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:text="Aucune note"
                    android:textColor="@color/textColor"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/emptyStateSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Appuie sur + pour commencer."
                    android:textColor="@color/textColorBis"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/componentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/trashDropZone"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="18dp"
        android:layout_marginBottom="88dp"
        android:background="@drawable/trash_drop_zone"
        android:gravity="center"
        android:text="Glisse ici pour supprimer"
        android:textColor="@color/textColor"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- FAB en bas à droite -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnCreatePage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="click"
        app:tint="@color/textColorBis"
        android:backgroundTint="@color/bgColorBis"
        app:srcCompat="@android:drawable/ic_input_add" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
