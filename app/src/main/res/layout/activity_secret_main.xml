<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDarkColor"
    android:fitsSystemWindows="true">

    <!-- AppBarLayout enveloppant ton layout custom -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="@color/bgDarkColor">

        <!-- Ta "toolbar" custom -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mainAppBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_page_item"
            android:backgroundTint="@color/bgDarkColorBis"
            android:fitsSystemWindows="false">

            <!-- Conteneur horizontal -->
            <LinearLayout
                android:id="@+id/appBarContent"
                android:layout_width="0dp"
                android:layout_height="?attr/actionBarSize"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Icône hamburger -->
                <ImageView
                    android:id="@+id/secretMenuReturn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="18dp"
                    android:src="@drawable/ic_back_arrow"
                    app:tint="@color/textDarkColorBis"
                    android:contentDescription="Menu icon" />

                <!-- Titre -->
                <TextView
                    android:id="@+id/toolbarTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Secret memories of Lilas"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-light"
                    android:textColor="@color/textDarkColor"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ScrollView qui démarre sous la barre grâce au comportement -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:contentDescription="srollview des pages"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/componentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"/>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>