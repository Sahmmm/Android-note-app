<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialogRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#33000000"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:id="@+id/linearLayoutMenu"
        android:layout_width="312dp"
        android:layout_height="match_parent"
        android:background="@drawable/menu_panel_bg"
        android:clickable="true"
        android:elevation="10dp"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="34dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/menu_panel_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/menu_icon_pill"
                android:gravity="center"
                android:text="✦"
                android:textColor="@color/textColor"
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:text="NoteApp"
                    android:textColor="@color/textColor"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Outils de Lilas"
                    android:textColor="@color/textColorBis"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="Bibliothèque"
            android:textColor="@color/textColorBis"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/menuNotes"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/menu_item_selected"
            android:clickable="true"
            android:drawableStart="@drawable/ic_note"
            android:drawablePadding="12dp"
            android:drawableTint="@color/bgDarkColor"
            android:focusable="true"
            android:fontFamily="sans-serif-light"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Notes"
            android:textColor="@color/textColor"
            android:textSize="19sp" />

        <TextView
            android:id="@+id/menuReminders"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/menu_item"
            android:clickable="true"
            android:drawableStart="@drawable/ic_rappel"
            android:drawablePadding="12dp"
            android:drawableTint="@color/bgDarkColor"
            android:focusable="true"
            android:fontFamily="sans-serif-light"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Rappels"
            android:textColor="@color/textColor"
            android:textSize="19sp" />

        <TextView
            android:id="@+id/menuLists"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/menu_item"
            android:clickable="true"
            android:drawableStart="@drawable/ic_liste"
            android:drawablePadding="12dp"
            android:drawableTint="@color/bgDarkColor"
            android:focusable="true"
            android:fontFamily="sans-serif-light"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Listes"
            android:textColor="@color/textColor"
            android:textSize="19sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/menu_hint_card"
            android:padding="14dp"
            android:text="Crée une page puis choisis son type pour la retrouver ici."
            android:textColor="@color/textColorBis"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/menu_item"
            android:clickable="true"
            android:drawableStart="@drawable/ic_settings"
            android:drawablePadding="12dp"
            android:drawableTint="@color/bgDarkColor"
            android:focusable="true"
            android:fontFamily="sans-serif-light"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Paramètres"
            android:textColor="@color/textColorBis"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/btnQuit"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/menu_item"
            android:clickable="true"
            android:drawableStart="@drawable/ic_logout"
            android:drawablePadding="12dp"
            android:drawableTint="@color/bgDarkColor"
            android:focusable="true"
            android:fontFamily="sans-serif-light"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Quitter"
            android:textColor="@color/textColorBis"
            android:textSize="18sp" />
    </LinearLayout>
</FrameLayout>