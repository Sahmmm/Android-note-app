<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialogRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true">

    <!-- Menu latéral -->
    <LinearLayout
        android:id="@+id/linearLayoutMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:background="@color/bgColor"
        android:clickable="true"
        android:elevation="2dp"
        android:stateListAnimator="@null"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:paddingHorizontal="18dp">

        <!-- Titre de l'application -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:text="NoteApp"
            android:textColor="@color/textColor"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:letterSpacing="0.05" />

        <!-- Ligne séparatrice sous le titre -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginBottom="16dp"
            android:background="@color/textColor"
            android:alpha="0.3" />

        <!-- Section principale -->
        <TextView
            android:id="@+id/menuNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_page_item"
            android:backgroundTint="@color/bgColorBis"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:drawableStart="@drawable/ic_note"
            android:drawablePadding="8dp"
            android:drawableTint="@color/bgDarkColor"
            android:text="Notes"
            android:fontFamily="sans-serif-light"
            android:textColor="@color/textColor"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/menuReminders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:drawableStart="@drawable/ic_rappel"
            android:drawablePadding="8dp"
            android:drawableTint="@color/bgDarkColor"
            android:padding="10dp"
            android:text="Rappels"
            android:textColor="@color/textColor"
            android:fontFamily="sans-serif-light"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/menuLists"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:drawableStart="@drawable/ic_liste"
            android:drawablePadding="8dp"
            android:drawableTint="@color/bgDarkColor"
            android:padding="10dp"
            android:text="Listes (...)"
            android:textColor="@color/textColor"
            android:fontFamily="sans-serif-light"
            android:textSize="20sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp"
            android:text="Pour les prochaines MAJ"
            android:textColor="#BD0404"
            android:textSize="18sp" />

        <!-- Espacement -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Ligne séparatrice -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="#22000000" />

        <!-- Section bas : paramètres + quitter -->
        <TextView
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:drawableStart="@drawable/ic_settings"
            android:drawablePadding="8dp"
            android:drawableTint="@color/bgDarkColor"
            android:focusable="true"
            android:paddingVertical="10dp"
            android:text="Paramètres"
            android:fontFamily="sans-serif-light"
            android:textColor="@color/textColorBis"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/btnQuit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:drawableStart="@drawable/ic_logout"
            android:drawablePadding="8dp"
            android:drawableTint="@color/bgDarkColor"
            android:focusable="true"
            android:paddingVertical="10dp"
            android:text="Quitter"
            android:fontFamily="sans-serif-light"
            android:textColor="@color/textColorBis"
            android:textSize="20sp" />

    </LinearLayout>
</FrameLayout>