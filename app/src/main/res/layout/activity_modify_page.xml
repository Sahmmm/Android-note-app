<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bluePastel"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintLayoutTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:background="#10000000"
            android:fitsSystemWindows="true">



            <!-- Image à gauche -->
            <ImageView
                android:id="@+id/imageReturnView"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:backgroundTint="@color/black"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_back_arrow" />

            <!-- Image à droite -->
            <ImageView
                android:id="@+id/imageOptionsView"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_more_vert" />

            <!-- Texte centré entre les deux images -->
            <TextView
                android:id="@+id/pageTitleView"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:text="TitleView"
                android:textAlignment="center"
                android:textSize="24sp"
                android:textColor="@color/textColor"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/imageOptionsView"
                app:layout_constraintStart_toEndOf="@id/imageReturnView"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <EditText
            android:id="@+id/editTextContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="top|start"
            android:hint="Écris ici..."
            android:textColorHint="#BC000000"
            android:textColor="@color/textColorBis"
            android:inputType="textMultiLine"
            android:maxLines="1000"
            android:overScrollMode="always"
            android:padding="16dp"
            android:scrollbars="vertical"
            android:textSize="16sp" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>